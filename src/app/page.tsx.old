        </p>

        <div className={styles.heroActions}>
          <a href="#waitlist" className={styles.btnPrimary}>
            Join the Waitlist — Get 50% Off at Launch
          </a>
          <a href="#method" className={styles.btnGhost}>
            Learn How It Works
          </a>
        </div>
      </div>
    </section>
  );
};

